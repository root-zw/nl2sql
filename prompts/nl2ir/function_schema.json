{
  "type": "function",
  "function": {
    "name": "produce_ir",
    "description": "将用户的自然语言查询转换为结构化的中间表示(IR)",
    "parameters": {
      "type": "object",
      "properties": {
        "query_type": {
          "type": "string",
          "enum": ["aggregation", "detail", "duplicate_detection", "window_detail"],
          "description": "查询类型"
        },
        "metrics": {
          "type": "array",
          "items": {
            "oneOf": [
              {"type": "string"},
              {
                "type": "object",
                "properties": {
                  "field": {"type": "string", "description": "字段UUID、__row_count__ 或 derived:名称"},
                  "aggregation": {
                    "type": "string",
                    "enum": ["SUM", "AVG", "MIN", "MAX", "COUNT"],
                    "default": "SUM",
                    "description": "聚合函数"
                  },
                  "alias": {"type": "string", "description": "结果列名（必填），应包含单位，如'最大值(万元)'"},
                  "decimal_places": {"type": "integer", "default": 2, "description": "小数位数，金额/面积建议2位，整数类可设为0"}
                },
                "required": ["field", "aggregation", "alias"]
              }
            ]
          },
          "description": "度量字段列表。支持两种格式：1)字符串UUID（默认SUM）；2)对象格式{field, aggregation, alias}。注意：__row_count__（记录数）必须用对象格式并设置合适的alias（如'宗数'、'记录数'、'数量'等，根据用户问题语境选择）"
        },
        "dimensions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "维度字段UUID列表。aggregation用于分组；detail用于指定展示列（LLM应根据问题上下文智能选择相关字段，为空则使用默认明细列）"
        },
        "filters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": {"type": "string", "description": "字段UUID"},
              "op": {
                "type": "string",
                "enum": ["=", "!=", ">", ">=", "<", "<=", "IN", "NOT IN", "LIKE", "IS NULL", "IS NOT NULL", "ST_INTERSECTS"],
                "description": "操作符：=精确匹配, IN多值, LIKE模糊(含%), IS NULL空值, ST_INTERSECTS空间相交"
              },
              "value": {"description": "过滤值：单值、数组或几何WKT"}
            },
            "required": ["field", "op"]
          },
          "description": "WHERE过滤条件（聚合前）"
        },
        "having_filters": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": {"type": "string", "description": "聚合指标字段UUID或派生指标（如 derived:每亩单价）"},
              "op": {"type": "string", "enum": ["=", "!=", ">", ">=", "<", "<="]},
              "value": {"description": "数值（需按指标定义的单位填写）"}
            },
            "required": ["field", "op", "value"]
          },
          "description": "HAVING过滤条件（聚合后），用于对聚合结果或派生指标进行过滤"
        },
        "conditional_metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "field": {"type": "string", "description": "聚合字段UUID或__row_count__"},
              "condition": {
                "type": "object",
                "properties": {
                  "field": {"type": "string"},
                  "op": {"type": "string", "enum": ["=", "!=", ">", ">=", "<", "<=", "IN", "NOT IN", "LIKE"]},
                  "value": {}
                },
                "required": ["field", "op", "value"]
              },
              "aggregation": {
                "type": "string",
                "enum": ["SUM", "COUNT", "AVG", "MIN", "MAX"],
                "default": "SUM"
              },
              "alias": {"type": "string"},
              "else_value": {"default": 0},
              "decimal_places": {"type": "integer", "default": 2, "description": "小数位数，默认2位"}
            },
            "required": ["field", "condition", "alias"]
          },
          "description": "条件聚合，生成 ROUND(SUM(CASE WHEN ... THEN ... ELSE 0 END), 2)"
        },
        "ratio_metrics": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "numerator_field": {"type": "string", "description": "分子字段UUID或__row_count__"},
              "numerator_condition": {
                "type": "object",
                "properties": {
                  "field": {"type": "string"},
                  "op": {"type": "string"},
                  "value": {}
                }
              },
              "denominator_field": {"type": "string", "description": "分母字段UUID，不指定则用COUNT(*)"},
              "denominator_condition": {
                "type": "object",
                "properties": {
                  "field": {"type": "string"},
                  "op": {"type": "string"},
                  "value": {}
                }
              },
              "alias": {"type": "string"},
              "as_percentage": {"type": "boolean", "default": true},
              "decimal_places": {"type": "integer", "default": 2}
            },
            "required": ["numerator_field", "alias"]
          },
          "description": "占比/通过率计算"
        },
        "calculated_fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "expression": {"type": "string", "description": "如 {uuid_a} * {uuid_b}，比率类如 ({uuid_a} - {uuid_b}) / {uuid_b} * 100"},
              "alias": {"type": "string"},
              "field_refs": {
                "type": "array",
                "items": {"type": "string"},
                "description": "表达式中引用的字段UUID"
              },
              "aggregation": {
                "type": "string",
                "enum": ["AVG", "SUM", "MAX", "MIN", "NONE"],
                "description": "聚合查询中对表达式应用的聚合函数。AVG求平均，NONE表示表达式内部已包含聚合逻辑"
              },
              "unit": {
                "type": "string",
                "description": "单位。注意：比率类指标（如溢价率、增长率）不应有单位或单位为'%'"
              },
              "decimal_places": {
                "type": "integer",
                "default": 2,
                "description": "小数位数，默认2位"
              },
              "total_strategy": {
                "type": "string",
                "enum": ["sum", "recalculate", "weighted_avg", "max", "min", "none"],
                "description": "合计行计算策略：sum=直接求和（绝对值指标如金额），recalculate=重新计算公式（比率类如溢价率、占比），weighted_avg=加权平均，max/min=取最大/最小值，none=不显示合计。如不指定则根据expression自动推断"
              },
              "numerator_refs": {
                "type": "array",
                "items": {"type": "string"},
                "description": "分子引用的字段UUID列表（仅比率类指标，total_strategy=recalculate时需要）"
              },
              "denominator_refs": {
                "type": "array",
                "items": {"type": "string"},
                "description": "分母引用的字段UUID列表（仅比率类指标，total_strategy=recalculate时需要）"
              }
            },
            "required": ["expression", "alias"]
          },
          "description": "计算字段。比率类指标（包含除法的表达式）应设置 total_strategy=recalculate 并提供 numerator_refs 和 denominator_refs"
        },
        "time": {
          "type": "object",
          "properties": {
            "type": {"type": "string", "enum": ["absolute", "relative", "rolling"], "description": "absolute=明确日期范围, relative=相对时间段, rolling=当前周期至今"},
            "start_date": {"type": "string", "format": "date", "description": "起始日期（absolute类型必填）"},
            "end_date": {"type": "string", "format": "date", "description": "结束日期（absolute类型必填）"},
            "last_n": {"type": "integer", "description": "相对时间数量（relative类型必填），如近6年填6"},
            "unit": {"type": "string", "enum": ["day", "week", "month", "quarter", "year"], "description": "时间单位。year时系统优先使用年份字段，否则使用日期字段"},
            "grain": {"type": "string"},
            "offset": {"type": "integer"}
          },
          "description": "时间范围配置。unit=year时系统优先使用年份维度字段过滤，否则使用表的日期时间字段"
        },
        "time_grain": {
          "type": "string",
          "enum": ["day", "week", "month", "quarter", "year"],
          "description": "时间粒度"
        },
        "comparison_type": {
          "type": "string",
          "enum": ["yoy", "mom", "qoq", "wow"],
          "description": "对比类型：yoy同比年/mom环比月/qoq环比季/wow环比周"
        },
        "comparison_periods": {
          "type": "integer",
          "default": 1,
          "description": "对比周期数"
        },
        "show_growth_rate": {
          "type": "boolean",
          "default": true,
          "description": "是否显示增长率"
        },
        "cumulative_metrics": {
          "type": "array",
          "items": {"type": "string"},
          "description": "需累计计算的指标UUID列表"
        },
        "cumulative_order_by": {
          "type": "string",
          "description": "累计排序字段（通常是时间维度UUID）"
        },
        "moving_average_window": {
          "type": "integer",
          "description": "移动平均窗口大小"
        },
        "moving_average_metrics": {
          "type": "array",
          "items": {"type": "string"},
          "description": "需计算移动平均的指标UUID列表"
        },
        "partition_by": {
          "type": "array",
          "items": {"type": "string"},
          "description": "窗口分区字段（window_detail专用）"
        },
        "window_limit": {
          "type": "integer",
          "description": "窗口内记录数限制（window_detail专用）"
        },
        "duplicate_by": {
          "type": "array",
          "items": {"type": "string"},
          "description": "判断重复的字段列表（duplicate_detection专用）"
        },
        "sort_by": {
          "type": "string",
          "description": "排序字段UUID"
        },
        "sort_order": {
          "type": "string",
          "enum": ["asc", "desc"],
          "description": "排序方向"
        },
        "limit": {
          "type": "integer",
          "description": "返回记录数限制"
        },
        "with_total": {
          "type": "boolean",
          "description": "是否追加汇总行（aggregation专用）"
        },
        "join_strategy": {
          "type": "string",
          "enum": ["matched", "left_unmatched", "right_unmatched"],
          "default": "matched",
          "description": "JOIN策略"
        },
        "anti_join_table": {
          "type": "string",
          "description": "反向匹配参照表ID"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "解析置信度(0-1)"
        },
        "ambiguities": {
          "type": "array",
          "items": {"type": "string"},
          "description": "不确定或有歧义的地方"
        },
        "is_too_complex": {
          "type": "boolean",
          "description": "问题过于复杂，需拆解"
        },
        "complexity_reason": {
          "type": "string",
          "description": "复杂性原因"
        },
        "suggested_subquestions": {
          "type": "array",
          "items": {"type": "string"},
          "description": "建议拆解的子问题"
        },
        "requires_direct_sql": {
          "type": "boolean",
          "description": "需要直接SQL生成（CTE/递归/PIVOT等）"
        },
        "direct_sql_reason": {
          "type": "string",
          "description": "需要直接SQL的原因"
        },
        "cross_partition_query": {
          "type": "boolean",
          "description": "是否为跨分区查询（年份分区表的跨年对比或合并）"
        },
        "cross_partition_mode": {
          "type": "string",
          "enum": ["union", "compare", "multi_join"],
          "default": "union",
          "description": "跨分区模式：union(UNION ALL合并数据), compare(JOIN对比计算变化), multi_join(多表关联查询，找出同时存在于多个表中的记录)"
        },
        "compare_join_keys": {
          "type": "array",
          "items": {"type": "string"},
          "description": "cross_partition_mode=compare时的关联字段：简单汇总对比（用户只问整体变化率）时留空[]；明细对比（用户问各XX的变化）时填入关联字段UUID列表"
        },
        "cross_table_field_mappings": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          },
          "description": "跨表字段映射（多表查询必填）：{主表字段UUID: {其他表ID: 对应字段UUID}}。用于filters和compare_join_keys中字段在其他表的精确映射。示例：{'99cf5fcd-...': {'917983ce-...': 'abc123-...'}}"
        },
        "deduplicate_join_keys": {
          "type": "boolean",
          "default": true,
          "description": "multi_join模式下是否对主表JOIN键去重。true（默认）避免笛卡尔积数据膨胀，适用于'匹配检查'类查询；false保留完整关联，适用于需要看每条记录关联情况的场景"
        }
      },
      "required": ["query_type"]
    }
  }
}
