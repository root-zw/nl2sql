# Top1与Top2的最小分差（分差大于此值时直接执行）
LLM_TABLE_SELECTION_MIN_GAP=0.3
# 表选择确认卡每页展示数量（默认展示前N个）
LLM_TABLE_SELECTION_MAX_CANDIDATES=3
# 表选择总候选数量（用于"换一批"和"查看更多"功能，建议8-12）
LLM_TABLE_SELECTION_TOTAL_CANDIDATES=10
# 表选择每页展示数量（等同于MAX_CANDIDATES，用于分批展示）
LLM_TABLE_SELECTION_PAGE_SIZE=3
# LLM模式下每个字段最多传递的枚举值数量
LLM_TABLE_SELECTION_ENUM_PER_FIELD=5
# 跨年多表查询自动执行的置信度阈值（当 recommended_table_ids 中所有表置信度都 >= 此值时，直接执行无需确认）
LLM_TABLE_SELECTION_CROSS_YEAR_CONFIDENCE=0.75

# === 向量表选择配置 ===
# 向量选表的业务参数（置信度阈值、top_k、候选数等）已统一移至：
# config/retrieval_config.yaml 的 vector_table_selection 配置块
# 此处仅保留 LLM3 模型的 API 配置

# LLM3（向量表选择器）模型配置（独立于LLM1和LLM2）
# 如果不配置，默认使用NL2SQL_*的配置
# LLM_VECTOR_SELECTOR_BASE_URL=
# LLM_VECTOR_SELECTOR_API_KEY=
# LLM_VECTOR_SELECTOR_MODEL=
LLM_VECTOR_SELECTOR_TEMPERATURE=0.1
LLM_VECTOR_SELECTOR_MAX_TOKENS=4096
LLM_VECTOR_SELECTOR_TIMEOUT=60

# === 智能检索配置 ===
# 注意：检索算法参数统一在 config/retrieval_config.yaml 中配置
# Few-Shot Prompt标题（用于展示）
FEW_SHOT_PROMPT_SECTION_TITLE=【参考示例】
# 写入Few-Shot后是否立即同步Milvus（同步行为配置）
FEW_SHOT_IMMEDIATE_SYNC=false

# === Hybrid 检索配置 ===
# 枚举值与关键字段构建BM25文本时的重复因子（1~3）
HYBRID_VALUE_BOOST=3
# 允许写入Milvus的枚举基数阈值（超过后截断或跳过）
ENUM_CARDINALITY_THRESHOLD=5000
# BM25文本最大长度（字符），避免稀疏索引膨胀
BM25_TEXT_LIMIT=512
# Dense索引用于Embedding的原始文本最大长度
DENSE_TEXT_LIMIT=1024

# === Reranker 配置 ===
# Reranker 服务地址（vLLM /v1/rerank 接口）
# 示例：
#   - 本地服务：http://192.168.7.77:8889/v1 或 http://localhost:8080/v1
#   - SiliconFlow：https://api.siliconflow.cn/v1/rerank（注意：如果 endpoint 已包含 /rerank，直接使用；否则会自动添加）
# 注意：如果 endpoint 已经包含 /rerank，直接使用；如果只包含 /v1，会自动添加 /rerank
RERANKER_ENDPOINT=http://192.168.7.77:8889/v1
# Reranker 模型名称
# 示例：
#   - 本地模型：bge-reranker-v2-m3
#   - SiliconFlow：BAAI/bge-reranker-v2-m3（注意：SiliconFlow 需要完整的模型路径）
RERANKER_MODEL=bge-reranker-v2-m3
# Reranker API Key（用于需要认证的服务，如 SiliconFlow）
# 示例：sk-xxx（SiliconFlow 的 API Key）
# 注意：如果使用 SiliconFlow 等需要认证的服务，必须设置此值
RERANKER_API_KEY=
# Reranker 请求超时（秒）
RERANKER_TIMEOUT=30
# Reranker 最大并发数（批量处理时）
RERANKER_MAX_CONCURRENT=5

# === 测试/巡检配置 ===
# 多通道巡检脚本 API 基础地址
QA_TEST_API_BASE=http://127.0.0.1:8890
# Query API 路径
QA_TEST_QUERY_PATH=/api/query
# 测试用户与角色
# admin 的真实 user_id（来自元数据库 users 表）
QA_TEST_USER_ID=d66b5cd1-4715-41ff-849a-3cad14a5fd34
QA_TEST_ROLE=admin
# 可选：用于自动化登录（脚本会在未提供 token 时尝试 /api/admin/login）
QA_TEST_USERNAME=admin
QA_TEST_PASSWORD=admin123
# 可选：在本地测试环境“铸造”JWT（无需走验证码/登录接口）
# - 依赖 .env 中的 JWT_SECRET / JWT_ALGORITHM / JWT_EXPIRE_MINUTES
QA_TEST_MINT_TOKEN=false
# 是否强制执行 SQL（绕过确认）
QA_TEST_FORCE_EXECUTE=true
# 是否仅解释模式
QA_TEST_EXPLAIN_ONLY=false
# 是否跳过缓存
QA_TEST_SKIP_CACHE=false
# 是否关闭叙事生成
QA_TEST_DISABLE_NARRATIVE=true
# 限定业务域（可留空）
QA_TEST_DOMAIN_ID=
# API 超时（秒）
QA_TEST_API_TIMEOUT=180
# 会话前缀
QA_TEST_SESSION_PREFIX=multi-channel
# Trace 重试次数与延迟
QA_TEST_TRACE_RETRY=5
QA_TEST_TRACE_DELAY=0.8
# 指定连接 ID/名称（可选，优先于数据库自动选择）
QA_TEST_CONNECTION_ID=
QA_TEST_CONNECTION_NAME=
# 是否输出字段候选（默认关闭）
QA_TEST_SHOW_FIELD_CANDIDATES=true
# 字段候选最大条数
QA_TEST_FIELD_CANDIDATE_LIMIT=60
# 可选：Bearer access_token（这里应填写“登录后拿到的 JWT”，而不是 JWT_SECRET）
QA_TEST_ACCESS_TOKEN=

