# ==========================================
# 智能问数环境配置
# ==========================================
# 使用方法：修改配置后复制为 .env 文件
# cp env.template .env
# ==========================================

# === 应用与服务配置 ===
# 应用运行环境 (development/test/production)
APP_ENV=development
# 应用展示名称
APP_NAME=智能问数
# 服务日志级别
LOG_LEVEL=INFO
# 默认系统时区（IANA 名称）
TIMEZONE=Asia/Shanghai
# FastAPI 监听主机
SERVER_HOST=0.0.0.0
# FastAPI 监听端口
SERVER_PORT=8891
# 允许的跨域来源（逗号分隔，* 表示全部）
CORS_ALLOW_ORIGINS=*

# === LLM 默认配置（必填）===
# LLM 服务提供商标识（custom=OpenAI 兼容接口）
LLM_PROVIDER=custom
# OpenAI 兼容接口基础 URL
NL2SQL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI 兼容接口的 API Key
NL2SQL_API_KEY=sk-aecaaa7d4ecc4d8381a755b16c617d65
# 默认模型名称（如 qwen3-14b、gpt-4o-mini）
LLM_MODEL=qwen3-14b
# 单次请求超时（秒）
LLM_TIMEOUT=60
# 请求重试次数
LLM_MAX_RETRIES=2
# 是否启用 Function Calling
LLM_USE_TOOLS=true
# 是否启用 JSON Mode
LLM_USE_JSON_MODE=false
# 模型温度（0-1）
LLM_TEMPERATURE=0.0
# Top-P 采样参数
LLM_TOP_P=0.1
# 最大输出 token 数
LLM_MAX_TOKENS=2048
# 是否启用"思考/推理"扩展
LLM_ENABLE_THINKING=false

# === LLM 多场景配置（可选，未配置时回退到默认配置）===
# 每个场景可单独指定不同的模型、API 等

# --- 表选择场景 (LLM_TABLE_SELECTION_*) ---
# 用于 LLM 智能选表，适合使用小模型降低成本
# LLM_TABLE_SELECTION_BASE_URL=
# LLM_TABLE_SELECTION_API_KEY=
# LLM_TABLE_SELECTION_MODEL=qwen-turbo
# LLM_TABLE_SELECTION_TEMPERATURE=0.0
# LLM_TABLE_SELECTION_MAX_TOKENS=2048  # 建议至少2048，避免输出被截断导致JSON解析失败
# LLM_TABLE_SELECTION_TIMEOUT=30

# --- NL2IR 解析场景 (LLM_NL2IR_*) ---
# 用于自然语言转 IR，核心场景，建议使用高质量模型
# LLM_NL2IR_BASE_URL=
# LLM_NL2IR_API_KEY=
# LLM_NL2IR_MODEL=qwen3-14b
# LLM_NL2IR_TEMPERATURE=0.0
# LLM_NL2IR_MAX_TOKENS=2048
# LLM_NL2IR_TIMEOUT=60

# --- 叙述生成场景 (LLM_NARRATIVE_*) ---
# 用于生成自然语言总结，适合使用创意型模型
# LLM_NARRATIVE_BASE_URL=
# LLM_NARRATIVE_API_KEY=
# LLM_NARRATIVE_MODEL=qwen-turbo
# 注意：叙述温度使用 NARRATIVE_TEMPERATURE 配置（见下方叙述功能配置）
# LLM_NARRATIVE_MAX_TOKENS=3072
# LLM_NARRATIVE_TIMEOUT=60

# === Embedding 配置 ===
# Embedding 服务地址
# 支持 Ollama（http://127.0.0.1:11434）或 vLLM/OpenAI 兼容接口
EMBEDDING_BASE_URL=http://127.0.0.1:11434
# Embedding API Key（Ollama 可设为 dummy）
EMBEDDING_API_KEY=dummy
# Embedding 模型名称
EMBEDDING_MODEL=bge-m3
# Embedding 向量维度
EMBEDDING_DIM=1024
# Embedding 请求超时（秒）
EMBEDDING_TIMEOUT=30
# Embedding 批量处理大小（vLLM 支持真批量，Ollama 使用并发模拟）
EMBEDDING_BATCH_SIZE=16
# Embedding 最大并发数（用于 Ollama 模式）
EMBEDDING_MAX_CONCURRENT=10

# === 业务数据库连接（供健康检查使用）===
# SQL Server 主机（旧版管理方式）
DB_HOST=127.0.0.1
# SQL Server 端口
DB_PORT=1433
# SQL Server 数据库名
DB_NAME=sde
# SQL Server 用户名
DB_USER=sa
# SQL Server 密码
DB_PASSWORD=zhuquezhihui1234!
# SQL Server 驱动名称
DB_DRIVER=ODBC Driver 18 for SQL Server
# 是否启用加密 (yes/no)
DB_ENCRYPT=yes
# 是否信任服务器证书 (yes/no)
DB_TRUST_SERVER_CERTIFICATE=yes

# === 数据库驱动/超时配置 ===
# FreeTDS 驱动路径
FREETDS_DRIVER_PATH=/usr/lib/x86_64-linux-gnu/odbc/libtdsodbc.so
# FreeTDS TDS 协议版本
FREETDS_VERSION=7.3
# SQLAlchemy 主连接池大小
DB_POOL_SIZE=10
# SQLAlchemy 允许的额外连接数
DB_POOL_MAX_OVERFLOW=20
# SQLAlchemy 获取连接超时（秒）
DB_POOL_TIMEOUT=30
# ODBC/Async 连接超时（秒）
DB_CONNECT_TIMEOUT=30
# ODBC/Async 命令超时（秒）
DB_COMMAND_TIMEOUT=60
# 目标数据库连接池大小（多租户连接）
TARGET_DB_POOL_SIZE=20
# 目标数据库连接池最大溢出
TARGET_DB_POOL_MAX_OVERFLOW=50
# 目标数据库获取连接超时（秒）
TARGET_DB_POOL_TIMEOUT=30
# 目标数据库连接回收时间（秒）
TARGET_DB_POOL_RECYCLE=3600
# 数据库检查器连接超时（秒）
DB_INSPECTOR_TIMEOUT=5

# === 缓存/Redis 配置 ===
# 是否启用查询缓存
CACHE_ENABLED=false
# Redis 连接串（用于缓存）
REDIS_URL=redis://localhost:26379/0
# Redis 认证密码
REDIS_PASSWORD=
# 自动同步模块 Redis 主机
REDIS_HOST=localhost
# 自动同步模块 Redis 端口
REDIS_PORT=26379
# 自动同步模块 Redis DB
REDIS_DB=1
# 是否启用自动同步 Redis
REDIS_ENABLED=true
# Redis 最大连接数
REDIS_MAX_CONNECTIONS=50

# === PostgreSQL 元数据库 ===
# 元数据库主机
POSTGRES_HOST=localhost
# 元数据库端口
POSTGRES_PORT=25432
# 元数据库名称
POSTGRES_DB=text2sql_metadata
# 元数据库用户名
POSTGRES_USER=text2sql_user
# 元数据库密码（生产务必修改）
POSTGRES_PASSWORD=text2sql_secure_password_2024
# 元数据库最小连接数
METADATA_DB_POOL_MIN_SIZE=10
# 元数据库最大连接数
METADATA_DB_POOL_MAX_SIZE=100
# 元数据库命令超时（秒）
METADATA_DB_COMMAND_TIMEOUT=60
# 元数据库最大查询次数
METADATA_DB_MAX_QUERIES=50000
# 元数据库最大空闲存活时间（秒）
METADATA_DB_MAX_INACTIVE_LIFETIME=300
# 是否启用元数据库模式
USE_METADATA_DB=true
# 元数据缓存 TTL（秒）
METADATA_CACHE_TTL=1800

# === 安全配置 ===
# Fernet 加密密钥（用来加解密凭据）
ENCRYPTION_KEY=MbahmGrklJApETt6Md6OMS-fpdbJO3ZJjHlr-C274C0=
# JWT 密钥（生产必须替换）
JWT_SECRET=your-strong-secret-key-for-jwt-2024
# JWT Token 算法
JWT_ALGORITHM=HS256
# Access Token 过期时间（分钟），建议 15-60 分钟
JWT_EXPIRE_MINUTES=30
# Refresh Token 过期时间（天），建议 7-30 天
JWT_REFRESH_EXPIRE_DAYS=7

# === 认证配置 ===
# 前端基础 URL（用于 OIDC 回调重定向等场景）
# 开发环境示例：http://localhost:3000
# 生产环境示例：https://your-domain.com
FRONTEND_URL=

# 认证模式：local/oidc/api_gateway/ldap/chain；chain 为多 provider 链式尝试
AUTH_MODE=local
# 注册的认证提供者列表，逗号分隔；用于控制哪些 provider 被加载
AUTH_PROVIDERS=local

# === 自动化测试/开发辅助 ===
# 是否启用登录验证码校验（生产建议 true；自动化测试可设为 false）
AUTH_CAPTCHA_ENABLED=true

# OIDC / SSO
# 是否启用 OIDC/SSO 提供者
OIDC_ENABLED=false
# OIDC Issuer 地址（如 https://idp.example.com），用于发现文档与 JWKS
OIDC_ISSUER_URL=
# 在 IdP 注册的客户端 ID
OIDC_CLIENT_ID=
# 在 IdP 注册的客户端密钥（仅后端保存）
OIDC_CLIENT_SECRET=
# OIDC 回调地址（需与 IdP 配置一致）
OIDC_REDIRECT_URI=
# OIDC scope 列表
OIDC_SCOPE=openid profile email
# 外部角色到系统角色映射，* 为默认
OIDC_ROLE_MAPPING={"admin":"admin","manager":"data_admin","*":"user"}
# 从 Token 的哪个 claim 读取数据角色列表
OIDC_DATA_ROLE_CLAIM=roles
# 是否自动创建 Token 中不存在的数据角色
OIDC_AUTO_CREATE_DATA_ROLE=true
# 需要从 Token 同步到 user_attributes 的字段（逗号分隔）
OIDC_USER_ATTRIBUTE_CLAIMS=department,region

# API 网关
# 是否启用 API 网关认证
API_GATEWAY_ENABLED=false
# 网关签名密钥，用于校验上游签名
GATEWAY_SIGNATURE_SECRET=
# 可信网关 IP 列表，逗号分隔
TRUSTED_GATEWAY_IPS=
# API 网关模式是否自动创建数据角色
API_GATEWAY_AUTO_CREATE_ROLE=true

# LDAP
# 是否启用 LDAP 认证
LDAP_ENABLED=false
# LDAP 服务器地址（如 ldap://host:389 或 ldaps://host:636）
LDAP_SERVER=
# LDAP 搜索 Base DN
LDAP_BASE_DN=
# LDAP 绑定账户 DN
LDAP_BIND_DN=
# LDAP 绑定账户密码（仅后端保存）
LDAP_BIND_PASSWORD=

# === Milvus / 向量检索配置 ===
# 是否启用 Milvus
MILVUS_ENABLED=true
# Milvus 连接 URI
MILVUS_URI=http://localhost:19530
# Milvus Token（云服务可用）
MILVUS_TOKEN=
# 业务域集合名称
MILVUS_COLLECTION=semantic_metadata
# 枚举值集合名称
MILVUS_ENUM_COLLECTION=enum_values_dual
# Few-Shot SQL问答集合名称
MILVUS_FEW_SHOT_COLLECTION=qa_few_shot_samples
# Milvus 客户端池最小连接数
MILVUS_POOL_MIN_SIZE=1
# Milvus 客户端池最大连接数
MILVUS_POOL_MAX_SIZE=2
# 是否使用自定义中文 analyzer（启用后可配置停用词和过滤器）
# false: 使用内置的 "chinese" analyzer（不支持自定义参数，默认使用 jieba + cnalphanumonly）
# true: 使用自定义 analyzer（支持停用词、removepunct 等配置，推荐用于生产环境）
MILVUS_USE_CUSTOM_CHINESE_ANALYZER=true
# 中文停用词列表（逗号分隔，仅在启用自定义 analyzer 时生效）
# 常用中文停用词：的、了、在、是、我、有、和、就、不、人、都、一、一个、上、也、很、到、说、要、去、你、会、着、没有、看、好、自己、这、我们、你们、他们、她们、这个、那个、这些、那些、哪里、哪个、怎么、为什么、可能、可以、应该、非常、以及、并且、但是、如果、因为、所以、还是、就是、那么、这么、这样、那样、吗、呢、啊、哦、唉、的话、已经、正在、仍然、而且、与、及、由于、通过、其中、以上、以下、每个、一些
MILVUS_CHINESE_STOPWORDS=的,了,在,是,我,有,和,就,不,人,都,一,一个,上,也,很,到,说,要,去,你,会,着,没有,看,好,自己,这,我们,你们,他们,她们,这个,那个,这些,那些,哪里,哪个,怎么,为什么,可能,可以,应该,非常,以及,并且,但是,如果,因为,所以,还是,就是,那么,这么,这样,那样,吗,呢,啊,哦,唉,的话,已经,正在,仍然,而且,与,及,由于,通过,其中,以上,以下,每个,一些
# 是否移除标点符号（仅在启用自定义 analyzer 时生效，推荐启用以提高检索精度）
MILVUS_ANALYZER_REMOVE_PUNCT=true

# === 自动同步/并发控制 ===
# 自动同步批量大小
SYNC_MILVUS_BATCH_SIZE=100
# 同步任务默认超时时间（秒）
SYNC_DEFAULT_TIMEOUT_SECONDS=300
# 同步任务最大重试次数
SYNC_MAX_RETRY_ATTEMPTS=3
# 重试延迟基数（秒）
SYNC_RETRY_DELAY_BASE=5
# 通知队列读取超时（秒）
SYNC_NOTIFICATION_QUEUE_TIMEOUT=1.0
# 分布式锁默认超时时间（秒）
SYNC_LOCK_TIMEOUT_SECONDS=300
# 允许的最大并发同步任务数
SYNC_MAX_CONCURRENT=3
# 同步队列 Redis Key 前缀
SYNC_QUEUE_KEY_PREFIX=milvus_sync_queue
# 同步锁 Redis Key 前缀
SYNC_LOCK_KEY_PREFIX=milvus_lock
# 同步状态 Redis Key 前缀
SYNC_STATUS_KEY_PREFIX=milvus_status
# 字段更新后是否立即触发全量同步
IMMEDIATE_SYNC_ON_FIELD_UPDATE=true
# 表更新后是否立即触发全量同步
IMMEDIATE_SYNC_ON_TABLE_UPDATE=true
# 全量同步时是否包含Few-Shot
FEW_SHOT_SYNC_IN_FULL_SYNC=true
# 自动同步批量合并窗口（秒）
SYNC_BATCH_WINDOW_SECONDS=5
# 全量同步超时时间（秒）
SYNC_FULL_TIMEOUT_SECONDS=900
# 自动同步总开关
AUTO_SYNC_ENABLED=true
# 自动同步模式（auto/manual）
AUTO_SYNC_MODE=auto
# 各实体自动同步开关
AUTO_SYNC_DOMAINS=true
AUTO_SYNC_TABLES=true
AUTO_SYNC_FIELDS=true
AUTO_SYNC_ENUMS=true
AUTO_SYNC_FEW_SHOT=true

# === LLM 查询控制 ===
# SQL 查询超时（秒）
QUERY_TIMEOUT_SECONDS=120
# 默认返回行数
QUERY_DEFAULT_LIMIT=1000
# 最大返回行数
QUERY_MAX_LIMIT=10000

# === 多轮对话会话管理配置 ===
# 多轮对话上下文深度（包含多少轮历史对话作为上下文，0=不使用上下文）
CONVERSATION_CONTEXT_DEPTH=5
# 会话标题最大长度（自动从第一个问题截取）
CONVERSATION_TITLE_MAX_LENGTH=50
# 每个用户最大会话数量（0=不限制，超过时自动删除最旧的非置顶会话）
CONVERSATION_MAX_PER_USER=100
# 会话消息中是否保存完整的查询结果数据（true=保存完整数据，false=仅保存摘要）
CONVERSATION_SAVE_FULL_RESULT=true
# 查询结果最大保存行数（仅当 CONVERSATION_SAVE_FULL_RESULT=true 时有效）
CONVERSATION_MAX_RESULT_ROWS=500
# 查询取消等待超时（秒）
QUERY_CANCEL_TIMEOUT_SECONDS=10

# === 混合架构配置 ===
# 主开关：启用混合架构（IR + 直接SQL）
# 路由策略完全依赖LLM在IR中的标记（requires_direct_sql, is_too_complex等）
HYBRID_ARCHITECTURE_ENABLED=true
# 直接SQL开关：允许LLM直接生成SQL（当IR标记 requires_direct_sql=true 时使用）
DIRECT_SQL_ENABLED=true

# 直接SQL场景的LLM配置（可选，未配置时回退到默认配置）
# LLM_DIRECT_SQL_BASE_URL=
# LLM_DIRECT_SQL_API_KEY=
# LLM_DIRECT_SQL_MODEL=qwen3-14b
# LLM_DIRECT_SQL_TEMPERATURE=0.0
# LLM_DIRECT_SQL_MAX_TOKENS=4096
# LLM_DIRECT_SQL_TIMEOUT=60

# SQL后处理安全配置
# 是否对直接生成的SQL进行后处理（安全检查、权限注入）
SQL_POST_PROCESSOR_ENABLED=true
# 是否跳过表白名单验证（仅开发模式使用，生产环境务必设为false）
SQL_POST_PROCESSOR_SKIP_TABLE_VALIDATION=false
# 是否在直接SQL中注入权限过滤和默认过滤
SQL_POST_PROCESSOR_INJECT_FILTERS=true

# === 检索与确认策略 ===
# 层次化检索融合参数 α
RETRIEVAL_ALPHA=0.5
# 统一确认模式：always_confirm / adaptive
CONFIRMATION_MODE=always_confirm
# 确认卡时间窗口（天）
CONFIRM_TIME_SPAN_DAYS=90
# 低置信度阈值
CONFIRM_LOW_CONFIDENCE_THRESHOLD=0.7

# === 成本预估 / 计划 ===
# 是否启用 SHOWPLAN
SHOWPLAN_ENABLED=true
# SHOWPLAN 允许的最大行数
SHOWPLAN_ROWS_MAX=50000000
# SHOWPLAN 允许的最大成本
SHOWPLAN_COST_MAX=5.0

# === 查询验证与 DAG 配置 ===
# 是否启用增强验证
ENHANCED_VALIDATION_ENABLED=true
# 是否必须先执行 Dry Run
DRY_RUN_MANDATORY=true
# DAG 并发上限（0 表示自动）
COMPLEX_DAG_MAX_CONCURRENCY=0
# 是否启用 DAG 回退方案
COMPLEX_DAG_FALLBACK_ENABLED=true
# 智能上下文数值阈值
