# 智能上下文是否去重
SMART_CONTEXT_SUBQUERY_DISTINCT=true
# 智能上下文子查询别名
SMART_CONTEXT_SUBQUERY_ALIAS=ctx_subquery

# === 叙述生成功能 ===
