# === 数据限制配置 ===
# 解释器采样的最大行数
EXPLAINER_MAX_ROWS=1000
# 层次化 Prompt 中枚举值展示数量
MAX_ENUM_VALUES_IN_PROMPT=5

# === LLM 表选择配置 ===
# 是否启用 LLM 表选择（替代向量检索）
LLM_TABLE_SELECTION_ENABLED=true
# 高置信度阈值（直接执行，不需确认）
LLM_TABLE_SELECTION_HIGH_CONFIDENCE=0.85
# 中等置信度阈值（需用户确认）
